# Backend environment variables. Copy to backend/.env and fill in.
# See architecture-design.md §5.1 and §6.2. Never commit the real .env.

# Set automatically by docker-compose in local dev.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/content_gen

# Anthropic
ANTHROPIC_API_KEY=

# Google OAuth (from the GCP project — see build-plan Phase 3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# Session
JWT_SECRET=
JWT_EXPIRY_DAYS=7

# Refresh-token encryption — generate with Fernet.generate_key()
FERNET_KEY=

# Access control
ALLOWED_EMAIL_DOMAIN=digitaltreasury.com.au

# Frontend origin (CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Models
MODEL_GENERATION=claude-sonnet-4-6
MODEL_QA=claude-haiku-4-5-20251001

# Error tracking (optional in dev)
SENTRY_DSN=
