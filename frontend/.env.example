# Frontend environment variables. Copy to frontend/.env for local dev.
# See architecture-design.md §11.2. Never commit the real .env.

# Backend origin. Local dev points at the backend container; in production
# leave empty so requests go to the same origin and Netlify proxies /api.
VITE_API_BASE_URL=http://localhost:8000

# Error tracking (optional in dev)
VITE_SENTRY_DSN=
