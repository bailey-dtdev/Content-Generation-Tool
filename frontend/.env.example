# Frontend environment variables. Copy to frontend/.env for local dev.
# See architecture-design.md §11.2. Never commit the real .env.

# Backend API base. Local dev points at the backend container;
# in production this defaults to /api (Netlify proxies to the Fly backend).
VITE_API_BASE_URL=http://localhost:8000/api

# Error tracking (optional in dev)
VITE_SENTRY_DSN=
